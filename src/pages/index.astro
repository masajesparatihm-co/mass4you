---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import JobForm from '../components/JobForm.astro';

// === OPTIMIZACIÓN SEO CON PALABRAS CLAVE LOCALES E INCLUSIVAS ===
const title = "Trabaja con Nosotras | Convocatoria Masajistas Masajes para Ti";
const description = "Convocatoria abierta para masajistas y esteticistas en Soacha, Madrid, Funza y Bogotá. Excelentes ingresos, flexibilidad y seguridad para personal nacional y extranjero.";
---

<Layout title={title} description={description}>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">Masajes para Tí</a>
            <div class="nav-menu" style="display: flex; align-items: center;">
                <a href="/modelo" class="nav-link">Modelo de Negocio</a>
                <a href="/postulacion" class="nav-btn">Trabaja con Nosotras</a>
            </div>
        </div>
    </nav>

    <main class="hero-container">
        <header class="text-center">
            <h1>Masajes para Ti</h1>
            <p class="description">
                Somos un grupo de masajistas profesionales con experiencia, donde nuestros clientes son Fijos, Conocidos y Nuevos acorde a un estricto sistema de calificación, llevando cada servicio a una experiencia única llena de placer, discreción y absoluta seguridad.
            </p>
        </header>

        <div class="actions-wrapper triple-grid">
            <a href="/modelo" class="home-card-btn secondary-btn">
                <span class="icon">💡</span>
                <span class="btn-title">¿Cómo es el negocio?</span>
                <span class="btn-text">Mira cómo trabajamos y cómo se gana de forma justa y flexible.</span>
            </a>
         
            <a href="/servicio" class="home-card-btn client-btn">
                <span class="icon">✨</span>
                <span class="btn-title">Solicitar un Servicio</span>
                <span class="btn-text">Personaliza tu masaje ideal de forma segura y discreta.</span>
            </a>
         
            <a href="/postulacion" class="home-card-btn primary-btn">
                <span class="icon">🚀</span>
                <span class="btn-title">Trabaja con Nosotras</span>
                <span class="btn-text">Llena el formulario aquí para empezar tu proceso seguro hoy.</span>
            </a>
        </div>
    </main>
</Layout>

<style>
    :global(body) {
        background: #fff5f7 !important;
        margin: 0;
        padding: 0;
        font-family: system-ui, -apple-system, sans-serif !important;
        color: #222;
    }
    .hero-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
    }
    header {
        text-align: center;
        max-width: 750px;
        margin-bottom: 3rem;
    }
    h1 {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -0.05em;
        margin-bottom: 1rem;
        color: #d63384; 
    }
    .description {
        font-size: 1.15rem;
        line-height: 1.6;
        color: #4f4f4f;
    }
    .navbar {
        position: sticky;
        top: 0;
        left: 0;
        width: 100%;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(8px); 
        border-bottom: 1px solid rgba(214, 51, 132, 0.1);
        z-index: 1000;
        box-sizing: border-box;
    }
    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .logo {
        font-size: 1.3rem;
        font-weight: 700;
        color: #d63384;
        text-decoration: none;
        letter-spacing: -0.03em;
    }
    .nav-btn {
        background-color: #d63384;
        color: white;
        text-decoration: none;
        padding: 0.6rem 1.2rem;
        border-radius: 50px; 
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.2s ease;
        box-shadow: 0 2px 10px rgba(214, 51, 132, 0.15);
    }
    .nav-btn:hover {
        background-color: #b8236c;
        transform: translateY(-1px);
    }

    .hero-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 90vh;
        padding: 2rem 1.5rem 5rem 1.5rem; 
    }

    .nav-link {
        color: #4f4f4f;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        margin-right: 1.5rem;
        transition: color 0.2s ease;
    }
    .nav-link:hover {
        color: #d63384;
    }

    .actions-wrapper {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        width: 100%;
        max-width: 750px;
        margin-top: 2rem;
    }
    .home-card-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 2rem 1.5rem;
        border-radius: 16px;
        text-decoration: none;
        transition: all 0.25s ease;
        box-sizing: border-box;
    }
    .home-card-btn .icon {
        font-size: 2.5rem;
        margin-bottom: 0.8rem;
    }
    .home-card-btn .btn-title {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        display: block;
    }
    .home-card-btn .btn-text {
        font-size: 0.95rem;
        line-height: 1.4;
        opacity: 0.9;
    }
     
    .primary-btn {
        background-color: #d63384;
        color: white;
        box-shadow: 0 4px 15px rgba(214, 51, 132, 0.2);
    }
    .primary-btn:hover {
        background-color: #b8236c;
        transform: translateY(-3px);
    }
     
    .secondary-btn {
        background-color: white;
        color: #222;
        border: 2px solid rgba(214, 51, 132, 0.2);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
    }
    .secondary-btn .btn-title {
        color: #d63384;
    }
    .secondary-btn:hover {
        background-color: #fff5f7;
        border-color: #d63384;
        transform: translateY(-3px);
    }
     
    @media (max-width: 600px) {
        .actions-wrapper {
            grid-template-columns: 1fr;
            gap: 1.2rem;
        }
        .home-card-btn {
            padding: 1.5rem;
        }
    }
    
    .triple-grid {
        grid-template-columns: 1fr 1fr 1fr !important;
        max-width: 950px !important;
    }
     
    .client-btn {
        background-color: #222;
        color: white;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    }
    .client-btn .btn-title {
        color: #fff;
    }
    .client-btn:hover {
        background-color: #444;
        transform: translateY(-3px);
    }
     
    @media (max-width: 768px) {
        .triple-grid {
            grid-template-columns: 1fr !important;
        }
    }
</style>
