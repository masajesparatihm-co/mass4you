---
import Layout from '../layouts/Layout.astro';
import JobForm from '../components/JobForm.astro';
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trabaja con Nosotras - Masajes para Ti</title>
</head>
<body style="background: #fff5f7; margin: 0; padding: 0; font-family: system-ui, -apple-system, sans-serif; color: #222;">

    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">Masajes para Ti</a>
            <div class="nav-menu" style="display: flex; align-items: center;">
                <a href="/modelo" class="nav-link">Modelo de Negocio</a>
                <a href="/postulacion" class="nav-btn">Trabaja con Nosotras</a>
            </div>
        </div>
    </nav>

    <main class="page-container">
        <div class="form-wrapper">
            <div style="text-align: center; margin-bottom: 2rem;">
                <h2 style="color: #d63384; font-size: 2rem; margin-bottom: 0.5rem;">Formulario de Postulación</h2>
                <p style="color: #666; margin: 0;">Completa tus datos para iniciar el proceso de co-creación con nosotras.</p>
            </div>
            <JobForm />
        </div>
    </main>

</body>
</html>

<style>
    .navbar { position: sticky; top: 0; left: 0; width: 100%; background: rgba(255, 255, 255, 0.92); backdrop-filter: blur(8px); border-bottom: 1px solid rgba(214, 51, 132, 0.1); z-index: 1000; box-sizing: border-box; }
    .nav-container { max-width: 1200px; margin: 0 auto; padding: 1rem 1.5rem; display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 1.3rem; font-weight: 700; color: #d63384; text-decoration: none; }
    .nav-link { color: #4f4f4f; text-decoration: none; font-size: 0.95rem; font-weight: 500; margin-right: 1.5rem; }
    .nav-link:hover { color: #d63384; }
    .nav-btn { background-color: #d63384; color: white; text-decoration: none; padding: 0.6rem 1.2rem; border-radius: 50px; font-size: 0.9rem; font-weight: 600; }
    .page-container { max-width: 1200px; margin: 0 auto; display: flex; justify-content: center; align-items: center; min-height: 85vh; padding: 3rem 1.5rem; box-sizing: border-box; }
    .form-wrapper { width: 100%; display: flex; flex-direction: column; align-items: center; }
</style>
