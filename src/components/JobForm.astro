---
// src/components/JobForm.astro
---
<form id="applicationForm" class="app-form">
  
  <div class="grid-2">
    <div class="input-group">
      <label for="nombre_completo">Nombre Completo</label>
      <input type="text" id="nombre_completo" name="nombre_completo" required placeholder="Ej: María Camila Pérez" />
    </div>

    <div class="input-group">
      <label for="alias">Alias</label>
      <input type="text" id="alias" name="alias" required placeholder="Ej: Cami" />
    </div>
  </div>
  
    <!-- NUEVO CAMPO: DOCUMENTO DE IDENTIDAD PARA ANTECEDENTES -->
    <div class="input-group">
      <label for="cedula_postulante">Documento de Identidad (Cédula)</label>
      <input type="text" id="cedula_postulante" name="cedula_postulante" required placeholder="Ej: 10203040" />
    </div>

  <div class="grid-2">
    <div class="input-group">
      <label for="birth_date">Fecha de Nacimiento</label>
      <input type="date" id="birth_date" name="birth_date" required />
    </div>

    <div class="input-group">
      <label for="birth_place">Lugar de Nacimiento</label>
      <input type="text" id="birth_place" name="birth_place" required placeholder="Ej: Medellin" />
    </div>
  </div>

  <div class="grid-2">
    <div class="input-group">
      <label for="estado_civil">Estado Civil</label>
      <select id="estado_civil" name="estado_civil" required>
        <option value="">-- Seleccione --</option>
        <option value="Soltera">Soltera</option>
        <option value="Con pareja">Con pareja</option>
      </select>
    </div>

    <div class="input-group">
      <label for="genero">Género</label>
      <select id="genero" name="genero" required>
        <option value="">-- Seleccione --</option>
        <option value="Mujer">Mujer</option>
        <option value="Trans">Trans</option>
      </select>
    </div>
  </div>

  <div class="grid-3">
    <div class="input-group">
      <label for="tiene_hijos">¿Tiene hijos?</label>
      <select id="tiene_hijos" name="tiene_hijos" required>
        <option value="">-- Seleccione --</option>
        <option value="Sí">Sí</option>
        <option value="No">No</option>
      </select>
    </div>

    <div class="input-group">
      <label for="experiencia">¿Ha trabajado en esto antes?</label>
      <select id="experiencia" name="experiencia" required>
        <option value="">-- Seleccione --</option>
        <option value="Sí">Sí</option>
        <option value="No">No</option>
      </select>
    </div>

    <div class="input-group">
      <label for="estudios">¿Tiene estudios relacionados?</label>
      <select id="estudios" name="estudios" required>
        <option value="">-- Seleccione --</option>
        <option value="Sí">Sí</option>
        <option value="No">No</option>
      </select>
    </div>
  </div>

  <div class="grid-2">
    <div class="input-group">
      <label for="ultimo_salario">¿Cuál fue su último pago por hora? (Pesos COP)</label>
      <input type="number" id="ultimo_salario" name="ultimo_salario" min="0" required placeholder="Ej: 1500000" />
    </div>

    <div class="input-group">
      <label for="porcentaje_descuento">¿Cuál es el porcentaje de descuento sobre el pagoXhora?</label>
      <input type="number" id="porcentaje_descuento" name="porcentaje_descuento" min="0" max="100" required placeholder="Ej: 10" />
    </div>

    <div class="input-group">
      <label for="modalidad">Modalidad deseada</label>
      <select id="modalidad" name="modalidad" required>
        <option value="">-- Seleccione --</option>
        <option value="En sitio">En sitio</option>
        <option value="Híbrido">Híbrido</option>
        <option value="Domicilio">A domicilio</option>
      </select>
    </div>
  </div>

  <button type="submit" id="submitBtn">Enviar Postulación por WhatsApp 🚀</button>
</form>

<script>
  const WHATSAPP_PHONE = "573027645996"; 

  const form = document.getElementById('applicationForm') as HTMLFormElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);

    // Formatear salario a formato COP nativo ($1.500.000)
    const salarioCrudo = formData.get('ultimo_salario') as string;
    const salarioFormateado = new Intl.NumberFormat('es-CO', { 
      style: 'currency', 
      currency: 'COP', 
      maximumFractionDigits: 0 
    }).format(Number(salarioCrudo));

    // Construir mensaje directo estructurado
    const messageTemplate = 
`📝 *¡Nueva Postulación Recibida!*

👤 *Nombre:* ${formData.get('nombre_completo')}
🪪 *Cédula:* ${formData.get('cedula_postulante')}
🎭 *Alias:* ${formData.get('alias')}
📅 *F. Nacimiento:* ${formData.get('birth_date')}
📍 *Lugar Nacimiento:* ${formData.get('birth_place')}
💍 *Estado Civil:* ${formData.get('estado_civil')}
🧬 *Género:* ${formData.get('genero')}
👶 *Tiene Hijos:* ${formData.get('tiene_hijos')}
💼 *Experiencia Previa:* ${formData.get('experiencia')}
🎓 *Estudios Relacionados:* ${formData.get('estudios')}
💵 *Último Pago:* ${salarioFormateado}
📉 *Porcentaje Descuento:* ${formData.get('porcentaje_descuento')}%
🏠 *Modalidad:* ${formData.get('modalidad')}`;

    const encodedMessage = encodeURIComponent(messageTemplate);
    const whatsappUrl = `https://wa.me/${WHATSAPP_PHONE}?text=${encodedMessage}`;

    // 1. Mostrar alerta al usuario solicitando las imágenes manuales
    alert("Se abrirá WhatsApp. En el chat, recuerda adjuntar las imágenes que desees agregar a tu postulación.");

    // 2. Abrir la ventana de chat nativa inmediatamente
    window.open(whatsappUrl, '_blank', 'noopener,noreferrer');
    
    form.reset();
  });
</script>

<style>
  .app-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    max-width: 600px;
    background: #ffffff;
    padding: 2.5rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border: 1px solid #eaeaea;
    font-family: system-ui, sans-serif;
  }
  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .grid-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 480px) {
    .grid-2, .grid-3 {
      grid-template-columns: 1fr;
    }
  }
  label {
    font-weight: 600;
    font-size: 0.85rem;
    color: #444;
  }
  input, select {
    padding: 0.7rem;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 0.95rem;
    background-color: #fafafa;
  }
  input:focus, select:focus {
    outline: none;
    border-color: #25D366;
    background-color: #fff;
  }
  button {
    background-color: #25D366;
    color: white;
    padding: 1rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: bold;
    font-size: 1rem;
    margin-top: 1rem;
    transition: background-color 0.2s ease;
  }
  button:hover {
    background-color: #1ebd58;
  }
</style>
